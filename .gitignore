# ===== Secrets / environment =====
# Never commit real keys. The Supabase publishable key in script.js is browser-safe,
# but service_role keys, Groq keys, and any .env must stay out of the repo.
.env
.env.*
*.local.env
secrets.*

# ===== Claude Code =====
# Per-user permission approvals — machine-specific, not part of the app.
.claude/settings.local.json
# (Keep a shared .claude/settings.json or CLAUDE.md if you ever add one.)

# ===== Node / build (in case the React archive or tooling is reinstalled) =====
node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== Supabase CLI local state =====
supabase/.branches/
supabase/.temp/
supabase/.env

# ===== Data import scratch =====
# Temp folders from unpacking spreadsheets during doctor-data import.
_xlsx_tmp/

# ===== OS / OneDrive cruft =====
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
# Office lock files (e.g. ~$doctors_raw.xlsx) created while a file is open
~$*

# ===== Editors =====
.vscode/
.idea/
*.swp
