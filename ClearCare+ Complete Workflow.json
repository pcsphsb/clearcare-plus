        "url": "https://ossxctklhsoiiigixuvt.supabase.co/auth/v1/admin/generate_link",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
